[
  {
    "service": "did",
    "descrip": "get the public Decentralized Identifier (DID) for this agent",
    "synchronous": true,
    "http-request": "GET /cgi-bin/did",
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "<did>"
    }
  },
  {
    "service": "challenge",
    "descrip": "say hi - ask us for a new ADILOS identity challenge",
    "synchronous": true,
    "http-request": "GET /cgi-bin/challenge",
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "<challenge>"
    }
  },
  {
    "service": "response",
    "descrip": "provide your ADILOS response to our challenge",
    "synchronous": true,
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/response",
      "body": "JSON object with <rsp> and <chall> props"
    },
    "http-response": [
      {
        "context": "callers EC_PUBLIC_KEY was found and recognized okay",
        "status": "200 OK",
        "contenttype": "application/json",
        "content": "Hello <pubkey>"
      },
      {
        "context": "invalid challenge and/or bad response",
        "status": "400 Bad Request",
        "contenttype": "application/json",
        "content": "<message>"
      },
      {
        "context": "callers public key recognized, but banned",
        "status": "403 Forbidden",
        "contenttype": "application/json",
        "content": "<message>"
      },
      {
        "context": "callers public key is not registered",
        "status": "401 Unauthorized",
        "contenttype": "application/json",
        "content": "<message>"
      }
    ]
  },
  {
    "service": "encrequest",
    "descrip": "other agent can place an order, an encrypted request for service",
    "synchronous": false,
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/encrequest",
      "body": {
        "msghex": "<encrypted-message-containing-request>",
        "sighex": "<ecdsa-signature-of-message>",
        "spkhex": "<signers-EC-public-key>"
      }
    },
    "red-request": {
      "jsonrpc": "2.0",
      "method": "<service-endpoint>",
      "params": [
        "<service-specific-parameter-array>"
      ],
      "id": "<cookie>"
    },
    "red-result": [
      {
        "jsonrpc": "2.0",
        "result": "<service-specific-result-object>",
        "id": "<cookie>"
      },
      {
        "jsonrpc": "2.0",
        "error": {
          "code": "<errorcode>",
          "message": "errortxt"
        },
        "id": "<cookie>"
      }
    ],
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "ACK"
    }
  },
  {
    "service": "encresult",
    "descrip": "give us the encrypted result of our request for your service",
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/encresult",
      "body": {
        "msghex": "<encrypted-message-containing-response>",
        "sighex": "<ecdsa-signature-of-message>",
        "spkhex": "<signers-EC-public-key>"
      }
    },
    "red-request": [
      {
        "jsonrpc": "2.0",
        "result": "<service-specific-result-object>",
        "id": "<cookie>"
      },
      {
        "jsonrpc": "2.0",
        "error": {
          "code": "<errorcode>",
          "message": "<errortxt>"
        },
        "id": "<cookie>"
      }
    ],
    "red-result": null,
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "ACK"
    }
  }
]
