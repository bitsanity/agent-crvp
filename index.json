        "msghex": "<encrypted-message-containing-request>",
        "sighex": "<ecdsa-signature-of-message>",
        "spkhex": "<signers-EC-public-key>"
      }
    },
    "red-request": {
      "jsonrpc": "2.0",
      "method": "buy",
      "params": [ "<OrderId>" ],
      "id": "<cookie>"
    },
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "ACK"
    },
    "http-response": {
      "status": "402 Payment Required",
      "contenttype": "application/json",
      "content": "<fee-object>"
    }
  },

