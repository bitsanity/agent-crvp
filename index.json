[
  {
    "service": "timenow",
    "descrip": "Get the current time from this server",
    "http-request": "GET /cgi-bin/timenow",
    "authentication": false,
    "synchronous": true,
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "<unixtimestamp>"
    }
  },



  {
    "service": "orders",
    "descrip":
      "Any caller can fetch their Orders including ID and status",
    "authentication": true,
    "synchronous": true,
    "fee": null,
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/encrequest",
      "body": {
        "msghex": "<encrypted-message-containing-request>",
        "sighex": "<ecdsa-signature-of-message>",
        "spkhex": "<signers-EC-public-key>"
      }
    },
    "red-request": {
      "jsonrpc": "2.0",
      "method": "orders",
      "params": [],
      "id": "<cookie>"
    },
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "[ {OrderA}, {OrderB},...]"
    }
  },

  {
    "service": "submit",
    "descrip":
      "Seller submits details to make a new escrow contract transaction",
    "authentication": true,
    "synchronous": true,
    "fee": {
      "amt": "0.002 ether",
      "to": "0xf692826d69a8a7ed59e9ba35839dad582104bec6",
      "network": "Ethereum"
    },
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/encrequest",
      "body": {
        "msghex": "<encrypted-message-containing-request>",
        "sighex": "<ecdsa-signature-of-message>",
        "spkhex": "<signers-EC-public-key>"
      }
    },
    "red-request": {
      "jsonrpc": "2.0",
      "method": "submit",
      "params": [
        "<description>",
        "<price>",
        "<tokensca || 0 if ETH>",
        "<bond>",
        "<timeoutblocks>"
      ],
      "id": "<payment-txn-hash>"
    },
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "ACK"
    },
    "http-response": {
      "status": "402 Payment Required",
      "contenttype": "application/json",
      "content": "<fee-object>"
    }
  },

  {
    "service": "buy",
    "descrip":
      "Buyer requests transaction to place payment and bond into escrow",
    "authentication": true,
    "synchronous": true,
    "fee": {
      "amt": "<price+bond+fee>",
      "token": "0x-token-sca",
      "tokenunits": "number-of-token-units",
      "to": "0xf692826d69a8a7ed59e9ba35839dad582104bec6",
      "network": "Ethereum"
    },
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/encrequest",
