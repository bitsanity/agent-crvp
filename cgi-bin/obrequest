//
// main
//

if (! admin.fromWithinLAN() ) {
  admin.respondHttp( 401, "local only" )
}

if (! process.env.REQUEST_METHOD === 'POST' ) {
  admin.respondHttp( 405, "Please POST the request" )
}

let cookie = process.env.HTTP_COOKIE
if (!cookie) {
  admin.respondHttp( 400,
    "Cookie header required: to=pubkeyhex" )
}

//  Cookie: to=<pubkeyhex>
let topubkey = cookie.split('=')[1]

if (!topubkey || topubkey.length == 0)
  admin.respondHttp( 400, "Request <to> not found" )

process.stdin.on('data', data => {
  try {
    let body = JSON.parse( data.toString() )

    if (!body.method || !body.params || !body.id)
      throw 'body must be a JSON-RPC request'

    handlePost( topubkey, body )
  }
  catch( e ) {
    admin.respondHttp( 400, e.toString() )
  }
});

