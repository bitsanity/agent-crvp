const requests = require( './requests.js' )

async function handlePost( topubkey, reqobj ) {

  let privkeyhex = process.env.AGENT_PRIVKEYHEX
  if (!privkeyhex) {
    admin.respondHttp( 503, "key maintenance required" )
  }

  // TODO look up other agent's url by pubkey from social media
  let url = "1.2.3.4:8888"

  if (!url || url.length == 0)
    admin.respondHttp( 400, "url not located" )

  try {
    let blkreq = ecjson.redToBlack( privkeyhex, topubkey, reqobj )

//  let rsp = await fetch( 'http://' + url + '/cgibin/encrequest', {
//    method: "POST",
//    body: JSON.stringify(blkreq)
//  } )
//
//  let res = await rsp.text()

    let res = "test result"

    // TODO should we record outgoing requests and offer our agent an admin
    //      service to look up pending outgoing requests?

    admin.respondHttp( 200, res )
  }
  catch( e ) {
    admin.respondHttp( 500, e.toString() )
