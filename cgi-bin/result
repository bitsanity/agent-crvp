#!/usr/bin/node

// called locally by our agent when it has a result to send

const ecjson = require( 'ecjsonrpc' )
const admin = require( './admin.js' )
const requests = require( './requests.js' )

function handlePost( topubkey, cookie, replyobj ) {

  // TODO - look up URL for given pubkey from social media and ensure the
  // request is coming from there

  let privkeyhex = process.env.AGENT_PRIVKEYHEX
  if (!privkeyhex) {
    admin.respondHttp( 503, "key maintenance required" )
  }

  let redreslt = {
    jsonrpc: "2.0",
    result: replyobj,
    id: cookie
  }

  let blkresp = ecjson.redToBlack( privkeyhex, topubkey, redreslt )

  // TODO - post black response to other agent's URL by calling its encresult
  //        service

//fetch( 'http://' + url + '/cgibin/encresult', {
//  method: "POST",
//  body: JSON.stringify(blkresp)
//}

  requests.setResult( topubkey, cookie, replyobj )
  admin.respondHttp( 200, "ACK - sent" )
}

//
// main
//

if (! admin.fromWithinLAN() ) {
  admin.respondHttp( 401, "local only" )
}

if (! process.env.REQUEST_METHOD === 'POST' ) {
  admin.respondHttp( 405, "Please POST the result" )
}

let cookie = process.env.HTTP_COOKIE
if (!cookie) {
  admin.respondHttp( 400,
    "Cookie header required: agent=pubkeyhex&cookie=requestcookie" )
}

//  Cookie: agent=<pubkeyhex>&cookie=<requestcookie>
let cookieparts = cookie.split( "&" )
let topubkey = cookieparts[0].split('=')[1]
let reqcookie = cookieparts[1].split('=')[1]

if (!topubkey || !reqcookie)
  admin.respondHttp( 400, "Request cookie/id not found" )

process.stdin.on('data', data => {
  let body = JSON.parse( data.toString() )
  handlePost( topubkey, reqcookie, body )
});

