#!/usr/bin/node

// called locally by our agent when it has a result to send

const secp256k1 = require( 'secp256k1' )
const ecjson = require( 'ecjsonrpc' )
const env = require( './env.js' )
const admin = require( './admin.js' )
const acl = require( './acl.js' )
const requests = require( './requests.js' )

async function handlePost( topubkey, cookie, replyobj ) {

  let shortpub =
    secp256k1.publicKeyConvert( Buffer.from(topubkey,'hex'), true )

  let shortpubhex = Buffer.from(shortpub).toString('hex')
  let url = acl.pubkeyToHostPort( shortpubhex )
  if (!url) admin.respondHttp( 500, "unknown other party, no DID" )

  let privkeyhex = env.VARS.AGENT_PRIVKEYHEX
  if (!privkeyhex) {
    admin.respondHttp( 503, "key maintenance required" )
  }

  let redreslt = {
    jsonrpc: "2.0",
    result: replyobj,
    id: cookie
  }

  let blkresp = ecjson.redToBlack( privkeyhex, shortpub, redreslt )

  let rsp = await fetch( 'http://' + url + '/cgi-bin/encresult', {
    method: "POST",
    body: JSON.stringify(blkresp)
  } )

  if (!rsp.ok) {
    admin.respondHttp( 502, "remote encresult failed: " + rsp.status )
  }

  requests.setResult( shortpub, cookie, replyobj )
  admin.respondHttp( 200, "ACK" )
}

//
// main
//

if (! admin.fromWithinLAN() ) {
  admin.respondHttp( 401, "local only" )
}

if ( process.env.REQUEST_METHOD !== 'POST' ) {
  admin.respondHttp( 405, "Please POST the result" )
}

let cookie = process.env.HTTP_COOKIE
if (!cookie) {
  admin.respondHttp( 400,
    "Cookie header required: to=pubkeyhex; cookie=requestcookie" )
}

//  Cookie: agent=<pubkeyhex>; cookie=<requestcookie>
//  Also accept older form: agent=<pubkeyhex>&cookie=<requestcookie>
let cookieparts = cookie.split( /[;&]/ )
let cookiemap = {}
for (const part of cookieparts) {
  let kv = part.trim().split('=')
  cookiemap[kv[0]] = kv.slice(1).join('=')
}
let topubkey = cookiemap.agent
let reqcookie = cookiemap.cookie

if (!topubkey || !reqcookie)
  admin.respondHttp( 400, "Request cookie/id not found" )

process.stdin.on('data', async data => {
  try {
    let body = JSON.parse( data.toString() )
    await handlePost( topubkey, reqcookie, body )
  }
  catch( e ) {
    admin.respondHttp( 500, e.toString() )
  }
});
