[
  {
    "service": "register",
    "descrip": "register this agent's Decentralized Identifier (DID)",
    "synchronous": true,
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/register",
      "body": "<jsonobj>"
    },
    "http-response": {
      "status": "200 OK",
      "contenttype": "text/plain",
      "content": "ACK"
    }
  },
  {
    "service": "nexthello",
    "descrip": "retrieve the next new contact from the queue",
    "synchronous": true,
    "http-request": "GET /cgi-bin/nexthello",
    "http-response": {
      "status": "200 OK",
      "contenttype": "text/plain",
      "content": "pubkey=<pubkey> responded=<unixtimestamp>"
    }
  },
  {
    "service": "nextrequest",
    "descrip": "retrieve the next incoming request waiting for our service",
    "synchronous": true,
    "http-request": "GET /cgi-bin/nextrequest",
    "http-response": {
      "status": "200 OK",
      "contenttype": "text/plain",
      "content": "service=<service> params=[parms] agent=<pubkeyhex> cookie=<acookie>"
    }
  },
  {
    "service": "result",
    "descrip": "send this result of handling an incoming request to the requestor",
    "synchronous": true,
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/result",
      "header": "Cookie: agent=<pubkeyhex>&cookie=<requestcookie>",
      "body": "<resultobj>"
    },
    "http-response": {
      "status": "200 OK",
      "contenttype": "text/plain",
      "content": "ACK"
    }
  },
  {
    "service": "nextanswer",
    "descrip": "get the next result from another agent for one of our requests",
    "synchronous": true,
    "http-request": "GET /cgi-bin/nextanswer",
    "http-response": {
      "status": "200 OK",
      "contenttype": "text/plain",
      "content": "<null || {result} || {error}>"
    }
  },
  {
    "service": "obrequest",
    "descrip": "send an outbound encrypted request for service to another agent",
    "synchronous": true,
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/obrequest",
      "header": "Cookie: to=<pubkeyhex>",
      "body": "<red-json-rpc-request>"
    },
    "http-response": {
      "status": "200 OK",
      "contenttype": "text/plain",
      "content": "agents index.html file"
    }
  },
  {
    "service": "getmenu",
    "descrip": "retrieve another agent's menu of services",
    "synchronous": true,
    "http-request": "GET /cgi-bin/getmenu?agent=<agent>",
    "http-response": {
      "status": "200 OK",
      "contenttype": "text/plain",
      "content": "agents index.html file"
    }
  }
]
