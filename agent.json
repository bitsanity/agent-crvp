[
  {
    "service": "nexthello",
    "descrip": "retrieve the next new contact from the queue",
    "synchronous": true,
    "http-request": "GET /cgi-bin/nexthello",
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "{red-jsonrpc-obj}"
    }
  },
  {
    "service": "nextrequest",
    "descrip": "retrieve the next incoming request waiting for our service",
    "synchronous": true,
    "http-request": "GET /cgi-bin/nextrequest",
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "{red-jsonrpc-obj}"
    }
  },
  {
    "service": "result",
    "descrip":
      "send this result of handling an incoming request to the requestor",
    "synchronous": true,
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/result",
      "header": "Cookie: agent=<pubkeyhex>&cookie=<requestcookie>",
      "body": "<resultobj>"
    },
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "ACK"
    }
  },
  {
    "service": "nextanswer",
    "descrip":
      "get the next result from another agent for one of our requests",
    "synchronous": true,
    "http-request": "GET /cgi-bin/nextanswer",
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "{red-jsonrpc-obj}"
    }
  },
  {
    "service": "obrequest",
    "descrip":
      "send an outbound encrypted request for service to another agent",
    "synchronous": true,
    "http-request": {
      "method": "POST",
      "url": "/cgi-bin/obrequest",
      "header": "Cookie: to=<pubkeyhex>",
      "body": "{red-jsonrpc-obj}"
    },
    "http-response": {
      "status": "200 OK",
      "contenttype": "application/json",
      "content": "agents index.html file"
    }
  },
  {
    "service": "getmenu",
    "descrip": "retrieve another agent's menu of services",
    "synchronous": true,
    "http-request": "GET /cgi-bin/getmenu?agent=<agent>",
    "http-response": {
      "status": "200 OK",
      "contenttype": "text/html",
      "content": "agents index.html file"
    }
  }
]
